# Copy to `.env.local` and fill in values from the dashboards below.
# See docs/SETUP.md for the step-by-step account setup.

# --- Anthropic: https://console.anthropic.com
# Set a monthly spend cap in the console before deploying anywhere public.
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# --- Voyage AI: https://dashboard.voyageai.com
# voyage-4-lite has a 200M-token free tier — plenty for this project.
VOYAGE_API_KEY=pa-xxxx

# --- Supabase: https://supabase.com (Project Settings → API Keys)
# URL + publishable key are inlined into client JS by Next (NEXT_PUBLIC_*).
# Secret key is server-only and bypasses RLS — never ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx
SUPABASE_SECRET_KEY=sb_secret_xxxx

# --- Supabase: Project Settings → Database → Connection string → URI
# Unused at runtime right now (RAG goes through the REST client above), but
# kept so scripts and future migrations have a direct psql-compatible URL.
# IMPORTANT: URL-encode any reserved chars in the password (or just pick a
# password containing only [A-Za-z0-9._-]). The @ in your password will
# otherwise break URL parsing.
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
